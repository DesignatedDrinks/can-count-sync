# Shopify Dev Dashboard app credentials
# SHOPIFY_SHOP can be designated-drinks or designated-drinks.myshopify.com
SHOPIFY_SHOP=designated-drinks
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret
SHOPIFY_API_VERSION=2026-04

# Shopify inventory location to sync
# Run: npm run locations
SHOPIFY_LOCATION_ID=gid://shopify/Location/000000000000

# Google Sheet
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# For hosting, use this instead of a local JSON file:
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Webhook/server settings
PORT=3000
SHOPIFY_WEBHOOK_SECRET=your_client_secret_or_webhook_secret

# Inventory behavior
DEFAULT_SAFETY_BUFFER_CANS=0
